# ============================================================================
# 阿里云生产部署环境变量模板
# 用法：复制为 .env，填好后与 docker-compose.prod.yaml 放同一目录。
#   cp .env.prod.example .env
#   docker compose -f docker-compose.prod.yaml --env-file .env up -d
# 注意：.env 含密码，不要提交到 git。
# ============================================================================

# 阿里云 ACR 镜像地址（华南1/深圳，命名空间 wuzhixuan，仓库 coai）
# tag 用 git tag「release-v<版本>」触发自动构建后产出的「<版本>」，二者要一致。
# 例：打 tag release-v1.0.0 → 镜像为 ...coai:1.0.0，这里就写 :1.0.0。
COAI_IMAGE=registry.cn-shenzhen.aliyuncs.com/wuzhixuan/coai:1.0.0
# 若 ECS 也在「华南1/深圳」，改用 VPC 内网地址拉取（更快、不计公网流量）：
# COAI_IMAGE=registry-vpc.cn-shenzhen.aliyuncs.com/wuzhixuan/coai:1.0.0

# 宿主机对外端口（浏览器访问 http://服务器IP:此端口）
HOST_PORT=8000

# compose 自带 MySQL 的初始化账号（首次启动建库建用户用）
# 这些值同时被注入 chatnio 容器，作为它连库的账号，三处需一致。
MYSQL_ROOT_PASSWORD=change-me-root-pwd
MYSQL_DATABASE=chatnio
MYSQL_USER=chatnio
MYSQL_PASSWORD=change-me-app-pwd
