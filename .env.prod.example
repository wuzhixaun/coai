# ============================================================================
# 阿里云生产部署环境变量模板
# 用法：复制为 .env，与 docker-compose.prod.yaml 放同一目录。
#   cp .env.prod.example .env
#   docker compose -f docker-compose.prod.yaml --env-file .env up -d
# 注意：MySQL/Redis 连接不在这里配，沿用 config/config.yaml（外部地址）。
# ============================================================================

# 阿里云 ACR 镜像地址（华南1/深圳，命名空间 wuzhixuan，仓库 coai）
# 改成你已构建好的镜像版本号。
COAI_IMAGE=registry.cn-shenzhen.aliyuncs.com/wuzhixuan/coai:1.0.0
# 若 ECS 也在「华南1/深圳」，改用 VPC 内网地址拉取（更快、不计公网流量）：
# COAI_IMAGE=registry-vpc.cn-shenzhen.aliyuncs.com/wuzhixuan/coai:1.0.0

# 宿主机对外端口（浏览器访问 http://服务器IP:此端口）
HOST_PORT=8000
